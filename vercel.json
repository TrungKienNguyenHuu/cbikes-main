{
  "buildCommand": "npm run build",
  "installCommand": "npm install && cd backend && npm install",
  "outputDirectory": "build",
  "env": {
    "DATABASE_URL": "postgresql://postgres:postgres@localhost:5432/ecommerce_db",
    "NODE_ENV": "production"
  },
  "rewrites": [
    {
      "source": "/api/(.*)",
      "destination": "/api"
    },
    {
      "source": "/(.*)",
      "destination": "/index.html"
    }
  ]
}